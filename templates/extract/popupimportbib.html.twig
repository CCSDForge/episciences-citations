<div class="modal fade" id="modal-importbib" tabindex="-1"
     aria-labelledby="importBibModalTitle" aria-modal="true" role="dialog">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="importBibModalTitle">{{ 'Import BibTeX'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"
                        aria-label="{{ 'Close'|trans }}"></button>
            </div>
            <div class="modal-body">
                {{ form_widget(bibtexFile, {'id': 'bibtex-file', 'attr': {'class': 'form-control'}}) }}
                <div class="alert alert-warning mt-3 mb-0 d-flex align-items-center gap-2">
                    <i class="fa-solid fa-triangle-exclamation flex-shrink-0" aria-hidden="true"></i>
                    <em>{{ "The previous BibTeX references will be overwritten."|trans }}</em>
                </div>
            </div>
            <div class="modal-footer">
                {{ form_widget(btnCancelImportBib, {'id': 'cancel-adding-bib', 'attr': {'class': 'btn btn-outline-secondary', 'data-bs-dismiss': 'modal'}}) }}
                {{ form_widget(submitImportBib, {'id': 'confirm-adding-bib', 'attr': {'class': 'btn btn-success'}}) }}
            </div>
        </div>
    </div>
</div>
