<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1100;">
    <div id="closing-info-toast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
            <i class="fas fa-circle-info text-primary me-2" aria-hidden="true"></i>
            <strong class="me-auto">{{ 'Information'|trans }}</strong>
            <button type="button" class="btn-close" data-bs-dismiss="toast"
                    aria-label="{{ 'Close'|trans }}"></button>
        </div>
        <div class="toast-body">
            {{ 'To view your changes, go to your Episciences document page. You can continue editing if you wish.'|trans }}
        </div>
    </div>
</div>
