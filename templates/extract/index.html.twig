{% extends 'base.html.twig' %}

{% block title %}Episciences - Citations{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('extract') }}
{% endblock %}
{% block body %}

{# Loading screen overlay #}
<div id="loading-screen" class="d-none">
    <div class="position-fixed top-0 start-0 w-100 h-100 bg-dark bg-opacity-25" style="z-index:1040;"></div>
    <div class="position-fixed top-50 start-50 translate-middle text-center" style="z-index:1050;">
        <div class="spinner-border text-primary" role="status" style="width:3.5rem;height:3.5rem;">
            <span class="visually-hidden">{{ 'Loading...'|trans }}</span>
        </div>
        <div class="bg-white rounded-3 shadow px-4 py-2 mt-3">
            <span class="text-secondary small">{{ 'Saving...'|trans }}</span>
        </div>
    </div>
</div>

{% if app.session.get('openModalClose') is same as(1) %}
    {% include('extract/closingmodal.html.twig') %}
{% endif %}

{# Exact 50/50 two-column layout #}
<div class="row g-0" style="height:calc(100vh - 57px); overflow:hidden;">

    {# Left column: PDF viewer #}
    <div class="col-6 p-0 h-100">
        <iframe title="pdf-viewer" class="w-100 h-100 border-0"
                src="{{ path("app_get_pdf", {'docId': form.id.vars.value}) }}"
                allow="fullscreen"></iframe>
    </div>

    {# Right column: scrollable form #}
    <div class="col-6 h-100 overflow-y-auto border-start bg-light">

        {{ form_start(form, {'attr': {'id': 'form-extraction'}}) }}

        {% include("extract/popupaddref.html.twig") with form %}
        {% include("extract/popupimportbib.html.twig") with form %}

        {# Sticky toolbar — single row #}
        <div class="sticky-top bg-white border-bottom px-3 py-2 shadow-sm">
            <div class="d-flex gap-2">
                {{ form_widget(form.save, {
                    'label': '<i class="fas fa-floppy-disk me-1" aria-hidden="true"></i>'~'Save'|trans,
                    'label_html': true,
                    'attr': {'class': 'btn btn-sm btn-primary flex-fill fw-semibold'}
                }) }}
                {{ form_widget(form.btnModalNewReference, {
                    'id': 'btn-modal-addref',
                    'label': '<i class="fas fa-plus me-1" aria-hidden="true"></i>'~'Add reference'|trans,
                    'label_html': true,
                    'attr': {'class': 'btn btn-sm btn-success flex-fill'}
                }) }}

                {# Actions dropdown: Extract, Import, Accept all, Decline all #}
                <div class="dropdown flex-fill">
                    <button class="btn btn-sm btn-outline-secondary w-100 dropdown-toggle" type="button"
                            data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-sliders me-1" aria-hidden="true"></i>
                        {{ "Actions"|trans }}
                    </button>
                    <ul class="dropdown-menu">
                        <li>
                            <button id="extract-all" class="dropdown-item"
                                    data-url-from-epi="{{ app.session.get('EpiPdfUrltoExtract') }}">
                                <i class="fas fa-file-pdf me-2 text-warning" aria-hidden="true"></i>
                                {{ "Extract from PDF"|trans }}
                            </button>
                        </li>
                        <li>
                            <button type="button" id="btn-modal-importbibtex"
                                    name="{{ form.btnModalImportBibtex.vars.full_name }}"
                                    class="dropdown-item">
                                <i class="fas fa-file-import me-2" aria-hidden="true"></i>
                                {{ 'Import BibTeX'|trans }}
                            </button>
                            {% do form.btnModalImportBibtex.setRendered() %}
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <button id="accept-all" class="dropdown-item">
                                <i class="fas fa-circle-check me-2 text-success" aria-hidden="true"></i>
                                {{ "Accept all"|trans }}
                            </button>
                        </li>
                        <li>
                            <button id="decline-all" class="dropdown-item">
                                <i class="fas fa-circle-xmark me-2 text-secondary" aria-hidden="true"></i>
                                {{ "Decline all"|trans }}
                            </button>
                        </li>
                    </ul>
                </div>

                {% if form.paperReferences|length > 0 %}
                <button type="button" id="select-delete-ref" class="btn btn-sm btn-danger flex-fill">
                    <i class="fas fa-trash me-1" aria-hidden="true"></i>
                    {{ "Remove"|trans }}
                </button>
                <button type="button" id="cancel-delete-ref" class="btn btn-sm btn-outline-secondary flex-fill d-none">
                    <i class="fas fa-rotate-left me-1" aria-hidden="true"></i>
                    {{ "Cancel"|trans }}
                </button>
                <button type="button" id="toggle-select-all-ref" class="btn btn-sm btn-secondary flex-fill d-none"
                        data-select-label="{{ 'Select all'|trans }}"
                        data-deselect-label="{{ 'Deselect all'|trans }}">
                    <i class="fas fa-check-double me-1" aria-hidden="true"></i><span>{{ "Select all"|trans }}</span>
                </button>
                {% endif %}
            </div>
        </div>

        {# Main form content area #}
        <div class="px-3 py-3">

            {# Empty state #}
            {% if form.paperReferences|length is same as(0) %}
                <div class="d-flex box-height-none-ref w-100 justify-content-center color-box-none mb-4 mt-2">
                    <p class="m-auto text-muted">{{ "No references were extracted or found"|trans }}</p>
                </div>
                {{ form_row(form.paperReferences, {'attr': {'class': 'd-none'}}) }}
            {% else %}

            {# Delete mode alert #}
            <div id="alert-remove" class="alert alert-warning alert-dismissible fade show mb-3 d-none" role="alert">
                <i class="fas fa-circle-info me-2" aria-hidden="true"></i>
                {{ "To delete references, use the checkboxes to select the reference you wish to delete and click on the Save button"|trans }}
                <button id="btn-close-remove" type="button" class="btn-close" data-bs-dismiss="alert"
                        aria-label="{{ 'Close'|trans }}"></button>
            </div>

            {# Reference list (sortable) #}
            <div id="sortref">
                {% for paperReferences in form.paperReferences %}
                    {% set jsonDecodedRef = prettyReference(paperReferences.reference.vars.data) %}
                    {% set doiDecodedRef = '' %}
                    {% set isDeclined = paperReferences.vars.value.accepted is same as(0) %}

                    <div id="container-reference"
                         class="card mb-2 shadow-sm{% if isDeclined %} filtered declinedRef{% endif %}"
                         data-idref="{{ paperReferences.id.vars.value }}">
                        <div class="card-body p-3">

                            {{ form_widget(paperReferences.reference, {'id': 'reference-'~paperReferences.id.vars.value, 'attr': {'class': 'd-none'}}) }}

                            {# Reference text (read mode) #}
                            <div id="container-reference-informations-{{ paperReferences.id.vars.value }}"
                                 style="cursor:pointer"
                                 title="{{ 'Click to edit'|trans }}"
                                 role="button">
                                <p id="textReference-{{ paperReferences.id.vars.value }}" class="mb-1 small">
                                    {{ jsonDecodedRef['raw_reference'] }}
                                </p>
                                {% if jsonDecodedRef['doi'] is defined %}
                                    <a href="https://doi.org/{{ jsonDecodedRef['doi'] }}"
                                       class="link-primary small text-decoration-underline"
                                       rel="noopener" target="_blank"
                                       id="linkDoiRef-{{ paperReferences.id.vars.value }}">
                                        <i class="fas fa-external-link-alt me-1" aria-hidden="true"></i>{{ jsonDecodedRef['doi'] }}
                                    </a>
                                    {% set doiDecodedRef = jsonDecodedRef['doi'] %}
                                {% endif %}
                            </div>

                            {# Edit mode fields (hidden by default) #}
                            <div class="d-none" id="modifyTextArea-{{ paperReferences.id.vars.value }}">
                                <textarea id="textareaRef-{{ paperReferences.id.vars.value }}"
                                          class="form-control textarea-height">{{ jsonDecodedRef['raw_reference'] }}</textarea>
                            </div>
                            <div class="d-none w-100" id="modifyReferenceDoi-{{ paperReferences.id.vars.value }}">
                                <input type="text" id="textDoiRef-{{ paperReferences.id.vars.value }}"
                                       class="form-control form-control-sm"
                                       placeholder="{{ 'DOI, URL'|trans }}"
                                       value="{{ doiDecodedRef }}">
                            </div>
                            <div class="d-none mt-2 d-flex gap-2" id="editActionBtns-{{ paperReferences.id.vars.value }}">
                                <button type="button" id="acceptModifyBtn-{{ paperReferences.id.vars.value }}"
                                        class="btn btn-sm btn-success flex-grow-1">
                                    <i class="fas fa-check me-1" aria-hidden="true"></i>{{ 'Confirm'|trans }}
                                </button>
                                <button type="button" id="cancelModifyBtn-{{ paperReferences.id.vars.value }}"
                                        class="btn btn-sm btn-outline-secondary flex-grow-1">
                                    <i class="fas fa-xmark me-1" aria-hidden="true"></i>{{ 'Cancel'|trans }}
                                </button>
                            </div>

                            {# Card footer: controls + source badge #}
                            <div class="d-flex align-items-center gap-2 mt-2 pt-2 border-top">
                                {# Left controls #}
                                <div id="selection-references" class="d-flex align-items-center gap-2 flex-grow-1 ref-controls">
                                    {% set classModifyBtn = (jsonDecodedRef['forbiddenModify'] is not defined) ? 'btn btn-sm btn-secondary' : 'd-none' %}
                                    <button type="button"
                                            id="modifyBtn-{{ paperReferences.id.vars.value }}"
                                            data-idref="{{ paperReferences.id.vars.value }}"
                                            class="{{ classModifyBtn }}">
                                        <i class="fas fa-pen me-1" aria-hidden="true"></i>{{ 'Edit'|trans }}
                                    </button>

                                    {# Accept/Decline toggle #}
                                    <div class="form-check form-switch mb-0 ref-toggle">
                                        <input class="form-check-input" type="checkbox" role="switch"
                                               id="toggle-input-{{ paperReferences.id.vars.value }}"
                                               value="{{ paperReferences.id.vars.value }}"
                                               {% if paperReferences.accepted.vars.data is same as(1) %} checked{% endif %}>
                                        <label class="form-check-label visually-hidden"
                                               for="toggle-input-{{ paperReferences.id.vars.value }}">
                                            {{ 'Accept reference'|trans }}
                                        </label>
                                    </div>
                                </div>

                                {# Delete checkbox (hidden by default, shown in delete mode) #}
                                {{ form_widget(paperReferences.checkboxIdTodelete, {
                                    'id': 'ref-to-delete-'~paperReferences.id.vars.value,
                                    'attr': {
                                        'data-idref-del': paperReferences.id.vars.value,
                                        'class': 'form-check-input d-none ref-delete-check',
                                        'style': 'width:1.4rem;height:1.4rem;accent-color:#e74c3c;cursor:pointer;'
                                    }
                                }) }}

                                {# Source badge #}
                                <span class="badge source-color-{{ paperReferences.vars.data.source|lower }} ms-auto">
                                    {{ paperReferences.vars.data.source|trans }}
                                </span>
                            </div>

                        </div>

                        {{ form_widget(paperReferences.isDirtyTextAreaModifyRef, {
                            'id': 'is-dirty-textarea-modify-ref-'~paperReferences.id.vars.value,
                            'attr': {'data-dirty-ref': paperReferences.id.vars.value}
                        }) }}
                        {{ form_widget(paperReferences.accepted, {
                            'id': 'accepted-'~paperReferences.id.vars.value
                        }) }}
                        <div class="d-none">{{ form_row(paperReferences.id) }}</div>
                    </div>

                {% endfor %}
            </div>

            {% endif %}


        </div>

        {{ form_end(form) }}
    </div>
</div>
<input type="hidden" id="is-dirty" value="0">
{% endblock %}
