<nav class="navbar navbar-light bg-white border-bottom shadow-sm px-4">
    <a class="navbar-brand d-flex align-items-center gap-2" href="#">
        <img src="{{ asset('/img/Episciences_Logo.svg') }}" alt="Episciences logo" width="40" height="40">
        <span class="fw-semibold fs-5">{{ 'Episciences Citations'|trans }}</span>
    </a>
    {% if exception is not defined %}
    <div class="dropdown">
        <button class="btn btn-outline-secondary dropdown-toggle" type="button"
                id="languageDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="fas fa-globe text-primary me-1" aria-hidden="true"></i>
            <span class="text-uppercase fw-semibold">{{ app.request ? app.request.locale : 'en' }}</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="languageDropdown">
            <li>
                <a class="dropdown-item {% if app.request and app.request.locale == 'en' %}active{% endif %}"
                   href="{{ app.request ? path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|default({})|merge(app.request.query.all|merge({_locale: 'en'}))) : '#' }}">
                    <span class="fw-medium">EN</span>
                    <small class="text-muted d-block">English</small>
                </a>
            </li>
            <li>
                <a class="dropdown-item {% if app.request and app.request.locale == 'fr' %}active{% endif %}"
                   href="{{ app.request ? path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|default({})|merge(app.request.query.all|merge({_locale: 'fr'}))) : '#' }}">
                    <span class="fw-medium">FR</span>
                    <small class="text-muted d-block">Français</small>
                </a>
            </li>
        </ul>
    </div>
    {% endif %}
</nav>

{% set successFlashes = app.flashes('success') %}
{% set noticeFlashes = app.flashes('notice') %}
{% set errorFlashes = app.flashes('error') %}
{% if successFlashes|length > 0 or noticeFlashes|length > 0 or errorFlashes|length > 0 %}
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1100;" aria-live="polite" aria-atomic="true">

    {% for message in successFlashes %}
    <div class="toast align-items-center text-bg-success border-0 flash-toast mb-2" role="status" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center gap-2">
                <i class="fas fa-circle-check flex-shrink-0" aria-hidden="true"></i>
                {{ message }}
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                    aria-label="{{ 'Close'|trans }}"></button>
        </div>
        <div class="toast-progress"></div>
    </div>
    {% endfor %}

    {% for message in noticeFlashes %}
    <div class="toast align-items-center text-bg-warning border-0 flash-toast mb-2" role="status" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center gap-2">
                <i class="fas fa-triangle-exclamation flex-shrink-0" aria-hidden="true"></i>
                {{ message }}
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                    aria-label="{{ 'Close'|trans }}"></button>
        </div>
        <div class="toast-progress"></div>
    </div>
    {% endfor %}

    {% for message in errorFlashes %}
    <div class="toast align-items-center text-bg-danger border-0 flash-toast mb-2" role="status" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center gap-2">
                <i class="fas fa-circle-xmark flex-shrink-0" aria-hidden="true"></i>
                {{ message }}
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                    aria-label="{{ 'Close'|trans }}"></button>
        </div>
        <div class="toast-progress"></div>
    </div>
    {% endfor %}

</div>
{% endif %}
